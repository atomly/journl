{
  "name": "acme",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=9.15.9"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check --continue -- --write --unsafe",
    "check:dependencies": "pnpm dlx sherif@latest",
    "check:dependencies:fix": "pnpm dlx sherif@latest --fix",
    "clean": "turbo run clean && git clean -xdf .turbo node_modules",
    "db:push": "turbo -F @acme/db push",
    "db:studio": "turbo -F @acme/db studio",
    "dev": "turbo watch dev --continue",
    "typecheck": "turbo run typecheck",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.4",
    "@turbo/gen": "~2.8.10",
    "supabase": "^2.76.15",
    "turbo": "~2.8.10"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "zod": "^3.23.8 || ^4.0.0"
      },
      "ignoreMissing": [
        "@better-auth/passkey",
        "@daveyplate/better-auth-tanstack",
        "@instantdb/react",
        "@marsidev/react-turnstile",
        "@triplit/client",
        "@triplit/react"
      ]
    }
  }
}
